  "repository": {
    "type": "git",
    "url": "https://github.com/mizoz/openclaw-model-routing"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "chalk": "^4.1.2",
    "commander": "^11.1.0",
    "dotenv": "^16.3.1",
    "inquirer": "^8.2.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}