  "description": "Auto Model Routing for OpenClaw - Intelligent model selection based on task detection using Alibaba/Bailian models",
  "main": "src/index.js",
  "bin": {
    "omr": "./bin/omr.js"
  },
  "scripts": {
    "start": "node bin/omr.js",
