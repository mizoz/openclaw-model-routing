# Artificial Analysis API Key (required for model lookup)
# Get one free at https://artificialanalysis.ai
ARTIFICIAL_ANALYSIS_API_KEY=your_aa_api_key_here

# OpenClaw config path (optional, defaults to ~/.openclaw/openclaw.json)
OPENCLAW_CONFIG_PATH=~/.openclaw/openclaw.json

# Default model (optional, defaults to MiniMax-M2.5)
DEFAULT_MODEL=MiniMax-M2.5